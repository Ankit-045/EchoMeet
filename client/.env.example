# Frontend app origin used for shareable join links
VITE_PUBLIC_APP_URL=http://localhost:5173

# API base URL (for production set this to your deployed backend + /api)
# Example: https://echomeet-api.onrender.com/api
VITE_API_URL=/api

# Socket.io backend origin (for production set this to backend origin)
# Example: https://echomeet-api.onrender.com
VITE_BACKEND_URL=http://localhost:5000

# LiveKit SFU websocket URL
VITE_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
